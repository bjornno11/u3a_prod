{% load static %}
{% load i18n %} 
<!DOCTYPE html>
<html lang="no">
<head>
    <title>{% block title %}U3A Hjemmeside{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta charset="UTF-8">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="{% static 'css/u3a_styles.css' %}?v=6"> 
    <link rel="shortcut icon" type="image/x-icon" href="{% static 'favicon.ico' %}">
    <link rel="icon" type="image/png" href="{% static 'favicon.png' %}" sizes="32x32">
    {% block extra_head %}
    {% endblock extra_head %}
</head>
<body>

    <header class="header-container">
        <img class="u3a-logo" src="{% get_media_prefix %}u3a_logo1.png" alt="U3A Logo">
        <h1 class="main-heading">Velkommen til U3A, universitet for den tredje alder</h1>
    </header>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="{% url 'home' %}">U3A</a> 
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown" aria-controls="navbarNavDropdown" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarNavDropdown">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link active" aria-current="page" href="{% url 'home' %}">Hjem</a>
                    </li>
                    
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Lokallag
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="{% url 'lokallag_liste' %}">Alle lokallag</a></li> 
                            <li><a class="dropdown-item" href="/lokallag/kart/">Lokallag på kart</a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{% url 'regnskap' %}">Regnskap</a>
                    </li>
                    <li class="nav-item"><a class="nav-link" href="#">Om oss</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Aktiviteter</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Kontakt oss</a></li>
                </ul>
            </div>
        </div>
    </nav>
    
    <main class="container mt-4"> 
        {% block content %}
        {% endblock %}
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

{% block extra_script %}
{% endblock extra_script %}
</body>
</html>

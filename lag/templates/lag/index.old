{% load static %}
{% load i18n %} 
<!DOCTYPE html>
<html>
<head>
    <title>U3A</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

    <link rel="stylesheet" href="{% static 'css/u3a_styles.css' %}?v=5"> </head>
<body>
    
    <header class="header-container">
        <img class="u3a-logo" src="{% get_media_prefix %}u3a_logo1.png" alt="U3A Logo">
        <h1 class="main-heading">Velkommen til U3A, universitet for den tredje alder</h1>
    </header>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="#">U3A</a> 
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown" aria-controls="navbarNavDropdown" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarNavDropdown">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link active" aria-current="page" href="#">Hjem</a>
                    </li>
                    
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Lokallag
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/lokallag/liste/">Alle lokallag</a></li>
                            <li><a class="dropdown-item" href="/lokallag/kart/">Lokallag på kart</a></li>
                        </ul>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#">Om oss</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Aktiviteter</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Kontakt oss</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main style="padding: 20px;">
        <p>Siden er nå satt opp med ekstern CSS og riktig struktur.</p>
    </main>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

</body>
</html>

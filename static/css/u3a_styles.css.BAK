.u3a-norge-hero {
    min-height: 420px;
    background-image: linear-gradient(
        rgba(0, 45, 85, 0.70),
        rgba(0, 45, 85, 0.45)
    ), url("/static/lag/img/u3a-LLL.jpg");
    background-size: cover;
    background-position: center;
    border-radius: 0.75rem;
    overflow: hidden;
}

.u3a-norge-hero-overlay {
    min-height: 420px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 4rem;
    color: white;
}
